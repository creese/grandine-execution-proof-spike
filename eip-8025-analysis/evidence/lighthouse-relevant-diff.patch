+fn request_execution_proofs<T: BeaconChainTypes>(
+    chain: &Arc<BeaconChain<T>>,
+    execution_layer: &ExecutionLayer<T::EthSpec>,
+    new_payload_request: &NewPayloadRequest<'_, T::EthSpec>,
