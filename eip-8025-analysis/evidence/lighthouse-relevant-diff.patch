+            if let Err(error) = proof_engine
+                .request_proofs_ssz(request_body, proof_attributes)
+                .await
+            {
+                warn!(
+                    ?error,
+                    ?request_root,
+                    "Failed to request EIP-8025 execution proofs"
+                );
+            }
+        },
