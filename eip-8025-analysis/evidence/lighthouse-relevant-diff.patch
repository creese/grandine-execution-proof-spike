+    pub fn handle_execution_proofs_by_range_request(
+        &self,
+        peer_id: PeerId,
+        inbound_request_id: InboundRequestId,
+        req: ExecutionProofsByRangeRequest,
+    ) {
+        self.terminate_response_stream(
